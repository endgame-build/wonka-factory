    {
      "id": 11,
      "type": "stat",
      "title": "Accept rate",
      "description": "CAVEAT: with skipDangerousModePermissionPrompt=true every decision is source=config auto-accept, so this pegs at 100%. Meaningful only under gated permissions.",
      "gridPos": {
        "x": 0,
        "y": 30,
        "w": 6,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(claude_code_code_edit_tool_decision_total{decision=\"accept\"}) / sum(claude_code_code_edit_tool_decision_total)",
