            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(claude_code_lines_of_code_count_total{type=\"added\"}[$__rate_interval]))",
          "legendFormat": "Added",
          "range": true,
          "instant": false
